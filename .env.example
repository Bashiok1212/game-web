# 复制为 .env 并填写实际值
# cp .env.example .env

# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/game

# 生产环境必填：JWT 签名密钥，至少 32 位随机字符串
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-at-least-32-chars

# 服务端口
PORT=3000

# 生产环境（部署时必设）
NODE_ENV=production

# CORS 允许的域名，生产环境建议设为具体域名，如 https://yourdomain.com
# 多个用逗号分隔
CORS_ORIGIN=*
